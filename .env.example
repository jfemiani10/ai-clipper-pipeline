# =============================================================================
# AI Clipper — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env.
# =============================================================================

# --- Anthropic API ---------------------------------------------------------
# Your Anthropic API key. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Whisper ---------------------------------------------------------------
# Model size: tiny | base | small | medium | large-v2 | large-v3
# Larger models are more accurate but slower and use more RAM/VRAM.
# Recommended: base (fast, good accuracy), small (better accuracy, ~2x slower)
WHISPER_MODEL=base

# Language code for transcription (e.g. en, es, fr). Use 'auto' to let
# Whisper detect the language automatically.
WHISPER_LANGUAGE=en

# --- Clip Scoring ----------------------------------------------------------
# Minimum viral-potential score (0.0–1.0) for a moment to be clipped.
# Raise this to get fewer, higher-quality clips. Lower for more clips.
MIN_CLIP_SCORE=0.7

# --- Clip Timing -----------------------------------------------------------
# Seconds of padding to add before and after each detected clip timestamp.
CLIP_BUFFER_SECONDS=2

# Maximum allowed clip duration in seconds. Clips longer than this are skipped.
MAX_CLIP_DURATION=120

# --- Data Directories (relative to project root) ---------------------------
DOWNLOAD_DIR=data/downloads
TRANSCRIPT_DIR=data/transcripts
CLIPS_DIR=data/clips
EXPORT_DIR=data/exports

# --- Infrastructure --------------------------------------------------------
# Redis connection URL. Use redis://redis:6379 inside Docker Compose,
# or redis://localhost:6379 when running outside of Docker.
REDIS_URL=redis://redis:6379

# Path to the SQLite database file (relative to project root).
DATABASE_PATH=data/jobs.db

# --- Logging ---------------------------------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Claude Model (optional overrides) -------------------------------------
# The Claude model to use for highlight detection. Default is claude-sonnet-4-6.
CLAUDE_MODEL=claude-sonnet-4-6

# Maximum tokens in Claude's response (1024 is sufficient for JSON output).
CLAUDE_MAX_TOKENS=1024
